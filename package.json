{
  "name": "bench-this",
  "version": "0.5.0",
  "description": "Run @bench annotated functions and track performance regressions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bench-this": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "action.yml"
  ],
  "scripts": {
    "build": "tsc && pnpm build:action",
    "build:action": "esbuild src/action.ts --bundle --platform=node --target=node20 --outfile=dist/action-bundle.cjs --format=cjs --external:esbuild --external:playwright",
    "test": "node --import tsx/esm --test test/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "benchmark",
    "performance",
    "cli",
    "regression",
    "devtools"
  ],
  "author": "bkmsr",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "tinybench": "^6.0.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "esbuild": "^0.25.11",
    "typescript": "^6.0.2"
  }
}
